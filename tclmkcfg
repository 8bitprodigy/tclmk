#!/bin/sh
# tclmkcfg - tclmk Project Configurator
# The next line restarts using wish \
for interp in wish8.7 wish8.6 wish; do \
    command -v "$interp" >/dev/null 2>&1 && exec "$interp" "$0" "$@"; \
done; \
echo "tclmkcfg: no Tk interpreter found (Tk is required)" >&2; exit 1

# =============================================================================
# tclmkcfg -- tclmk Project Configurator
# Creates and edits .tclproj files for use with tclmk.
#
# Usage: tclmkcfg [file.tclproj]
# =============================================================================

package require Tcl 8.6
package require Tk

wm title . "tclmkcfg"
wm minsize . 800 560

# =============================================================================
# State
# =============================================================================
namespace eval ::cfg {
    # Current file on disk
    variable current_file ""
    variable dirty        0

    # Project metadata
    variable meta [dict create \
        name        "" \
        version     "0.1.0" \
        description "" \
        license     "0BSD"]

    # Sources: list of dicts {type file|dir path path excl 0|1}
    variable sources {}

    # Toolchains: dict of name -> toolchain-dict
    variable toolchains {}

    # Options/feature flags: dict of name -> option-dict
    variable options {}

    # Dependencies: list of dicts
    #   {name path url branch build_cmds inc_path lib_path lib_name platforms}
    #   platforms: dict of tc-name -> {build_cmds inc_path lib_path lib_name}
    variable deps {}
}

