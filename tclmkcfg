proc cfg::make_deps_tab {} {
    set f [ttk::frame .nb.deps]

    # Top: dependency list
    ttk::labelframe $f.list -text "Git Submodule Dependencies"

    ttk::treeview $f.list.tree \
        -columns {name url branch} \
        -show headings \
        -selectmode browse \
        -height 6 \
        -yscrollcommand [list $f.list.sb set]
    $f.list.tree heading name   -text "Name"   -anchor w
    $f.list.tree heading url    -text "URL"    -anchor w
    $f.list.tree heading branch -text "Branch" -anchor w
    $f.list.tree column  name   -width 120 -stretch 0
    $f.list.tree column  url    -width 280 -stretch 1
    $f.list.tree column  branch -width 80  -stretch 0
    ttk::scrollbar $f.list.sb -command [list $f.list.tree yview]

    ttk::frame $f.list.btns
    ttk::button $f.list.btns.add    -text "Add"    -command cfg::dep_add
    ttk::button $f.list.btns.remove -text "Remove" -command cfg::dep_remove
    pack $f.list.btns.add    -side left -padx {0 2}
    pack $f.list.btns.remove -side left

    grid $f.list.tree $f.list.sb -sticky nsew
    grid $f.list.btns -          -sticky ew   -pady {4 0}
    grid columnconfigure $f.list 0 -weight 1
    grid rowconfigure    $f.list 0 -weight 1

    # Bottom: editor
    ttk::labelframe $f.editor -text "Dependency Settings"

    set row 0

    # Fixed top-level identity fields: Name, URL, Path, Branch
    foreach {label key width hint} {
        "Name"   dep_name   22 "Identifier used in the project"
        "URL"    dep_url    40 "Git repository URL"
        "Path"   dep_path   28 "Local path (default: deps/<n>)"
        "Branch" dep_branch 18 "Branch, tag, or commit"
    } {
        ttk::label $f.editor.lbl_$key -text "$label:" -anchor e -width 12
        ttk::entry $f.editor.ent_$key \
            -textvariable ::cfg::dep_edit($key) -width $width
        ttk::label $f.editor.hint_$key -text $hint \
            -font {TkSmallCaptionFont}
        grid $f.editor.lbl_$key $f.editor.ent_$key \
            -row $row -padx 4 -pady 2 -sticky ew
        incr row
        grid $f.editor.hint_$key -row $row -column 1 \
            -padx 4 -pady {0 2} -sticky w
        incr row
    }

    # Separator before platform section
    ttk::separator $f.editor.sep -orient horizontal
    grid $f.editor.sep -row $row -column 0 -columnspan 2 \
        -sticky ew -padx 4 -pady 6
    incr row

    # Platform checkboxes — populated by dep_plt_refresh_checkboxes
    ttk::frame $f.editor.plts
    grid $f.editor.plts -row $row -column 0 -columnspan 2 \
        -sticky ew -padx 4 -pady {0 2}
    incr row

    # Platform dropdown
    ttk::label $f.editor.plt_lbl -text "Editing:" -anchor e -width 12
    ttk::combobox $f.editor.plt_dd \
        -textvariable ::cfg::dep_plt_current \
        -values       {Default} \
        -state        readonly \
        -width        20
    # Use a trace on the variable to capture the previous value
    # before <<ComboboxSelected>> fires with the new one
    trace add variable ::cfg::dep_plt_current write \
        cfg::dep_plt_on_change
    grid $f.editor.plt_lbl $f.editor.plt_dd \
        -row $row -padx 4 -pady {0 6} -sticky ew
    incr row

    # Inc / Lib / Libname — driven by selected platform
    foreach {label key width hint} {
        "Inc path" plt_inc  28 "Include path relative to dep root (for -I)"
        "Lib path" plt_lib  28 "Library path relative to dep root (for -L)"
        "Lib name" plt_libn 18 "Library name without lib prefix (for -l)"
    } {
        ttk::label $f.editor.lbl_$key -text "$label:" -anchor e -width 12
        ttk::entry $f.editor.ent_$key \
            -textvariable ::cfg::dep_plt_edit($key) -width $width
        ttk::label $f.editor.hint_$key -text $hint \
            -font {TkSmallCaptionFont}
        grid $f.editor.lbl_$key $f.editor.ent_$key \
            -row $row -padx 4 -pady 2 -sticky ew
        incr row
        grid $f.editor.hint_$key -row $row -column 1 \
            -padx 4 -pady {0 2} -sticky w
        incr row
    }

    # Build commands — at the bottom, driven by selected platform
    ttk::label $f.editor.lbl_cmds -text "Build cmds:" -anchor e -width 12
    ttk::frame $f.editor.cmds
    listbox $f.editor.cmds.lb \
        -listvariable ::cfg::dep_plt_cmds_display \
        -height 4 -width 36 -selectmode single \
        -yscrollcommand [list $f.editor.cmds.sb set]
    ttk::scrollbar $f.editor.cmds.sb -command [list $f.editor.cmds.lb yview]
    ttk::frame $f.editor.cmds.ctrl
    ttk::entry  $f.editor.cmds.ctrl.ent \
        -textvariable ::cfg::dep_plt_cmd_entry -width 30
    ttk::button $f.editor.cmds.ctrl.add -text "Add"    \
        -command cfg::dep_plt_cmd_add
    ttk::button $f.editor.cmds.ctrl.del -text "Remove" \
        -command cfg::dep_plt_cmd_remove
    ttk::button $f.editor.cmds.ctrl.up  -text "\u25b2" -width 2 \
        -command cfg::dep_plt_cmd_up
    ttk::button $f.editor.cmds.ctrl.dn  -text "\u25bc" -width 2 \
        -command cfg::dep_plt_cmd_down
    pack $f.editor.cmds.ctrl.ent -side left -padx {0 4}
    pack $f.editor.cmds.ctrl.add -side left -padx 2
    pack $f.editor.cmds.ctrl.del -side left -padx 2
    pack $f.editor.cmds.ctrl.up  -side left -padx 2
    pack $f.editor.cmds.ctrl.dn  -side left -padx 2
    pack $f.editor.cmds.lb   -side left -fill both -expand yes
    pack $f.editor.cmds.sb   -side left -fill y
    pack $f.editor.cmds.ctrl -side bottom -anchor w -pady {4 0}

    grid $f.editor.lbl_cmds $f.editor.cmds \
        -row $row -padx 4 -pady 4 -sticky nsew
    grid rowconfigure $f.editor $row -weight 1
    incr row

    ttk::label $f.editor.note \
        -text "Header-only: leave build commands empty, set inc path only.\nPlatform fields: blank inherits the Default value." \
        -font {TkSmallCaptionFont} -foreground gray -justify left
    grid $f.editor.note -row $row -column 1 \
        -padx 4 -pady {2 4} -sticky w
    incr row

    ttk::button $f.editor.apply -text "Apply" -command cfg::dep_apply
    grid $f.editor.apply -row $row -column 0 -columnspan 2 -pady 6

    grid columnconfigure $f.editor 1 -weight 1

    # Stack list on top, editor below
    grid $f.list   -row 0 -sticky nsew -padx 8 -pady {8 4}
    grid $f.editor -row 1 -sticky nsew -padx 8 -pady {4 8}
    grid rowconfigure $f 1 -weight 1
    grid columnconfigure $f 0 -weight 1

    bind $f.list.tree <<TreeviewSelect>> cfg::dep_on_select

    # Populate platform checkboxes now that toolchains are loaded
    after idle cfg::dep_plt_refresh_checkboxes

    return $f
}

namespace eval ::cfg {
    variable dep_edit
    array set dep_edit {
        dep_name "" dep_url "" dep_path "" dep_branch "main"
        dep_inc  "" dep_lib "" dep_libn ""
    }
    variable dep_current      -1
    variable dep_cmds         {}    ;# default build commands
    variable dep_cmds_display {}
    variable dep_cmd_entry    ""
    variable dep_platforms    {}    ;# dict of tc -> {build_cmds inc lib libn}
    variable dep_plt_current  "Default"
    variable dep_plt_prev     "Default"
    # Per-platform editor state
    variable dep_plt_edit
    array set dep_plt_edit {
        plt_inc "" plt_lib "" plt_libn ""
    }
    variable dep_plt_cmds         {}
    variable dep_plt_cmds_display {}
    variable dep_plt_cmd_entry    ""
}

proc cfg::dep_cmds_sync {} {
    set ::cfg::dep_cmds_display $::cfg::dep_cmds
}

proc cfg::dep_plt_cmds_sync {} {
    set ::cfg::dep_plt_cmds_display $::cfg::dep_plt_cmds
}

proc cfg::dep_plt_refresh_checkboxes {} {
    set f .nb.deps.editor.plts
    if {![winfo exists $f]} return
    foreach w [winfo children $f] { destroy $w }
    ttk::label $f.lbl -text "Platform overrides:"
    pack $f.lbl -side left -padx {0 6}
    dict for {tc _} $::cfg::toolchains {
        set var ::cfg::dep_plt_enabled($tc)
        set $var [dict exists $::cfg::dep_platforms $tc]
        ttk::checkbutton $f.cb_$tc \
            -text     $tc \
            -variable $var \
            -command  [list cfg::dep_plt_toggle $tc]
        pack $f.cb_$tc -side left -padx 4
    }
}

proc cfg::dep_plt_toggle {tc} {
    if {$::cfg::dep_plt_enabled($tc)} {
        if {![dict exists $::cfg::dep_platforms $tc]} {
            dict set ::cfg::dep_platforms $tc \
                [dict create build_cmds {} inc_path "" lib_path "" lib_name ""]
        }
    } else {
        set ::cfg::dep_platforms [dict remove $::cfg::dep_platforms $tc]
        if {$::cfg::dep_plt_current eq $tc} {
            cfg::dep_plt_select "Default"
        }
    }
    cfg::dep_plt_update_dropdown
}

proc cfg::dep_plt_update_dropdown {} {
    set dd .nb.deps.editor.plt_dd
    if {![winfo exists $dd]} return
    set values [list "Default"]
    dict for {tc _} $::cfg::dep_platforms { lappend values $tc }
    $dd configure -values $values
}

proc cfg::dep_plt_save {pname} {
    if {$pname eq "Default"} {
        set ::cfg::dep_cmds               $::cfg::dep_plt_cmds
        set ::cfg::dep_edit(dep_inc)      $::cfg::dep_plt_edit(plt_inc)
        set ::cfg::dep_edit(dep_lib)      $::cfg::dep_plt_edit(plt_lib)
        set ::cfg::dep_edit(dep_libn)     $::cfg::dep_plt_edit(plt_libn)
        return
    }
    set plt [dict create \
        build_cmds $::cfg::dep_plt_cmds \
        inc_path   [string trim $::cfg::dep_plt_edit(plt_inc)] \
        lib_path   [string trim $::cfg::dep_plt_edit(plt_lib)] \
        lib_name   [string trim $::cfg::dep_plt_edit(plt_libn)]]
    dict set ::cfg::dep_platforms $pname $plt
}

proc cfg::dep_plt_load {pname} {
    if {$pname eq "Default"} {
        set ::cfg::dep_plt_cmds           $::cfg::dep_cmds
        set ::cfg::dep_plt_edit(plt_inc)  $::cfg::dep_edit(dep_inc)
        set ::cfg::dep_plt_edit(plt_lib)  $::cfg::dep_edit(dep_lib)
        set ::cfg::dep_plt_edit(plt_libn) $::cfg::dep_edit(dep_libn)
    } else {
        if {[dict exists $::cfg::dep_platforms $pname]} {
            set plt [dict get $::cfg::dep_platforms $pname]
            set ::cfg::dep_plt_cmds           [dict get $plt build_cmds]
            set ::cfg::dep_plt_edit(plt_inc)  [dict get $plt inc_path]
            set ::cfg::dep_plt_edit(plt_lib)  [dict get $plt lib_path]
            set ::cfg::dep_plt_edit(plt_libn) [dict get $plt lib_name]
        } else {
            set ::cfg::dep_plt_cmds {}
            set ::cfg::dep_plt_edit(plt_inc)  ""
            set ::cfg::dep_plt_edit(plt_lib)  ""
            set ::cfg::dep_plt_edit(plt_libn) ""
        }
    }
    cfg::dep_plt_cmds_sync
}

proc cfg::dep_plt_on_change {args} {
    # Called when dep_plt_current changes — save old, load new
    # We track the previous value separately to avoid the race
    if {![info exists ::cfg::dep_plt_prev]} {
        set ::cfg::dep_plt_prev "Default"
    }
    set new $::cfg::dep_plt_current
    set old $::cfg::dep_plt_prev
    if {$new eq $old} return
    cfg::dep_plt_save $old
    set ::cfg::dep_plt_prev $new
    cfg::dep_plt_load $new
}

proc cfg::dep_plt_select {pname} {
    # Direct select (not via combobox) — save current, switch
    cfg::dep_plt_save $::cfg::dep_plt_current
    set ::cfg::dep_plt_prev $pname
    set ::cfg::dep_plt_current $pname
    cfg::dep_plt_load $pname
}

proc cfg::dep_plt_cmd_add {} {
    set cmd [string trim $::cfg::dep_plt_cmd_entry]
    if {$cmd eq ""} return
    lappend ::cfg::dep_plt_cmds $cmd
    cfg::dep_plt_cmds_sync
    set ::cfg::dep_plt_cmd_entry ""
}

proc cfg::dep_plt_cmd_remove {} {
