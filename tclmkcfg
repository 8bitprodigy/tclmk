    set ::cfg::dep_edit(dep_name)   ""
    set ::cfg::dep_edit(dep_url)    ""
    set ::cfg::dep_edit(dep_path)   ""
    set ::cfg::dep_edit(dep_branch) "main"
    set ::cfg::dep_edit(dep_inc)    ""
    set ::cfg::dep_edit(dep_lib)    ""
    set ::cfg::dep_edit(dep_libn)   ""
    set ::cfg::dep_cmds             {}
    set ::cfg::dep_platforms        {}
    set ::cfg::dep_plt_current      "Default"
    set ::cfg::dep_plt_prev         "Default"
    cfg::dep_cmds_sync
    cfg::dep_plt_refresh_checkboxes
    cfg::dep_plt_load "Default"
}

proc cfg::dep_remove {} {
    set tree .nb.deps.list.tree
    set sel  [$tree selection]
    if {$sel eq {}} return
    set idx [$tree index $sel]
    set ::cfg::deps [lreplace $::cfg::deps $idx $idx]
    cfg::refresh_deps
    cfg::mark_dirty
    cfg::refresh_preview
}

proc cfg::dep_apply {} {
    set name   [string trim $::cfg::dep_edit(dep_name)]
    set url    [string trim $::cfg::dep_edit(dep_url)]
    set path   [string trim $::cfg::dep_edit(dep_path)]
    set branch [string trim $::cfg::dep_edit(dep_branch)]
    set inc    [string trim $::cfg::dep_edit(dep_inc)]
    set lib    [string trim $::cfg::dep_edit(dep_lib)]
    set libn   [string trim $::cfg::dep_edit(dep_libn)]

    if {$name eq ""} {
        tk_messageBox -icon warning -title "tclmkcfg" \
            -message "Dependency name cannot be empty."
        return
    }
    if {$path   eq ""} { set path   "deps/$name" }
    if {$branch eq ""} { set branch "main" }

    # Save current platform editor state before applying
    cfg::dep_plt_save $::cfg::dep_plt_current

    set dep [dict create \
        name       $name \
        url        $url \
        path       $path \
        branch     $branch \
        build_cmds $::cfg::dep_cmds \
        inc_path   $inc \
        lib_path   $lib \
        lib_name   $libn \
        platforms  $::cfg::dep_platforms]

    if {$::cfg::dep_current >= 0} {
        set ::cfg::deps [lreplace $::cfg::deps \
            $::cfg::dep_current $::cfg::dep_current $dep]
    } else {
        lappend ::cfg::deps $dep
        set ::cfg::dep_current [expr {[llength $::cfg::deps] - 1}]
    }

    cfg::refresh_deps
    cfg::mark_dirty
    cfg::refresh_preview
}

