    if {$sel eq {}} return
    set ::cfg::dep_plt_cmds [lreplace $::cfg::dep_plt_cmds $sel $sel]
    cfg::dep_plt_cmds_sync
}

proc cfg::dep_plt_cmd_up {} {
    set lb  .nb.deps.editor.cmds.lb
    set sel [$lb curselection]
    if {$sel eq {} || $sel == 0} return
    set prev [expr {$sel - 1}]
    set a [lindex $::cfg::dep_plt_cmds $prev]
    set b [lindex $::cfg::dep_plt_cmds $sel]
    lset ::cfg::dep_plt_cmds $prev $b
    lset ::cfg::dep_plt_cmds $sel  $a
    cfg::dep_plt_cmds_sync
    $lb selection set $prev
}

proc cfg::dep_plt_cmd_down {} {
    set lb   .nb.deps.editor.cmds.lb
    set sel  [$lb curselection]
    set last [expr {[llength $::cfg::dep_plt_cmds] - 1}]
    if {$sel eq {} || $sel == $last} return
    set next [expr {$sel + 1}]
    set a [lindex $::cfg::dep_plt_cmds $sel]
    set b [lindex $::cfg::dep_plt_cmds $next]
    lset ::cfg::dep_plt_cmds $sel  $b
    lset ::cfg::dep_plt_cmds $next $a
