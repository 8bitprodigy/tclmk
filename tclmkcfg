    ttk::button $f.list.btns.add    -text "Add"    -command cfg::opt_add
    ttk::button $f.list.btns.remove -text "Remove" -command cfg::opt_remove
    pack $f.list.btns.add    -side left -padx 2
    pack $f.list.btns.remove -side left -padx 2
    pack $f.list.btns -side bottom -fill x -pady 2

    # Right: option editor
    ttk::labelframe $f.editor -text "Option Settings"

    set row 0
    foreach {label key width} {
        "Name"        opt_name   20
        "Description" opt_desc   32
    } {
        ttk::label $f.editor.lbl_$key -text "$label:" -anchor e -width 14
