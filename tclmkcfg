proc cfg::dep_on_select {} {
    set tree .nb.deps.list.tree
    set sel  [$tree selection]
    if {$sel eq {}} return
    set idx [$tree index $sel]
    set dep [lindex $::cfg::deps $idx]
    set ::cfg::dep_current $idx

    set ::cfg::dep_edit(dep_name)   [dict get $dep name]
    set ::cfg::dep_edit(dep_url)    [dict get $dep url]
    set ::cfg::dep_edit(dep_path)   [dict get $dep path]
    set ::cfg::dep_edit(dep_branch) [dict get $dep branch]
    set ::cfg::dep_edit(dep_inc)    [dict get $dep inc_path]
    set ::cfg::dep_edit(dep_lib)    [dict get $dep lib_path]
    set ::cfg::dep_edit(dep_libn)   [dict get $dep lib_name]
    set ::cfg::dep_cmds             [dict get $dep build_cmds]
    cfg::dep_cmds_sync

    if {[dict exists $dep platforms]} {
        set ::cfg::dep_platforms [dict get $dep platforms]
    } else {
        set ::cfg::dep_platforms {}
    }

    # Reset platform editor to Default view
    set ::cfg::dep_plt_current "Default"
    set ::cfg::dep_plt_prev    "Default"
    cfg::dep_plt_refresh_checkboxes
    cfg::dep_plt_load "Default"
}

