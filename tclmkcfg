            -row $row -padx 4 -pady 3 -sticky ew
        incr row
    }

    ttk::label $f.editor.lbl_def -text "Default:" -anchor e -width 14
    ttk::combobox $f.editor.ent_opt_default \
        -textvariable ::cfg::opt_edit(opt_default) \
        -values {0 1} -state readonly -width 4
    grid $f.editor.lbl_def $f.editor.ent_opt_default \
        -row $row -padx 4 -pady 3 -sticky w
    incr row

    ttk::label $f.editor.lbl_plat \
        -text "Platforms:" -anchor e -width 14
    ttk::entry $f.editor.ent_opt_platforms \
        -textvariable ::cfg::opt_edit(opt_platforms) -width 32
    ttk::label $f.editor.hint_plat \
        -text "(space-separated, blank = all)" \
        -font {TkSmallCaptionFont}
    grid $f.editor.lbl_plat $f.editor.ent_opt_platforms \
        -row $row -padx 4 -pady 3 -sticky ew
    incr row
    grid $f.editor.hint_plat -row $row -column 1 -padx 4 -sticky w
    incr row

    ttk::button $f.editor.apply -text "Apply" -command cfg::opt_apply
    grid $f.editor.apply -row $row -column 0 -columnspan 2 -pady 8

    grid columnconfigure $f.editor 1 -weight 1

    grid $f.list   -row 0 -column 0 -sticky nsew -padx {8 4} -pady 8
    grid $f.editor -row 0 -column 1 -sticky nsew -padx {4 8} -pady 8
    grid columnconfigure $f 1 -weight 1
    grid rowconfigure    $f 0 -weight 1

    bind $f.list.lb <<ListboxSelect>> cfg::opt_on_select

    return $f
}

