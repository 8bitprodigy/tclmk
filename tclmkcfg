proc cfg::make_tc_editor {f} {
    set row 0

    # Preset selector at top
    ttk::label  $f.plbl -text "Preset:" -anchor e -width 14
    ttk::combobox $f.preset \
        -values [dict keys [cfg::presets]] \
        -state  readonly -width 24
    bind $f.preset <<ComboboxSelected>> cfg::tc_apply_preset
    grid $f.plbl $f.preset -row $row -padx 4 -pady {6 8} -sticky ew
    incr row

    ttk::separator $f.sep -orient horizontal
    grid $f.sep -row $row -columnspan 2 -sticky ew -pady 4
    incr row

    # Name (editable)
    ttk::label $f.nlbl -text "Name:" -anchor e -width 14
    ttk::entry $f.name -textvariable ::cfg::tc_edit(name) -width 28
    grid $f.nlbl $f.name -row $row -padx 4 -pady 3 -sticky ew
    incr row

    # Simple string fields
    foreach {label key} {
        "C Compiler"   cc
        "C++ Compiler" cxx
        "Archiver"     ar
        "CFLAGS"       cflags
        "CXXFLAGS"     cxxflags
        "LDFLAGS"      ldflags
        "Defines"      defines
        "Includes"     includes
        "Sysroot"      sysroot
        "Output Dir"   outdir
        "Opt Levels"   opt_levels
        "Default -O"   default_olevel
    } {
        ttk::label $f.lbl_$key -text "$label:" -anchor e -width 14
        ttk::entry $f.ent_$key \
            -textvariable ::cfg::tc_edit($key) -width 28
        grid $f.lbl_$key $f.ent_$key -row $row -padx 4 -pady 2 -sticky ew
        incr row
    }

    # Debug flags sub-editor
    ttk::label $f.dflbl -text "Debug Flags:" -anchor e -width 14
    ttk::frame $f.dframe
    listbox $f.dframe.lb -listvariable ::cfg::tc_dbgflag_display \
        -height 4 -width 28 -selectmode single
    ttk::button $f.dframe.add -text "+" -width 2 \
        -command cfg::tc_dbgflag_add
    ttk::button $f.dframe.del -text "\u2212" -width 2 \
        -command cfg::tc_dbgflag_remove
    pack $f.dframe.lb  -side left -fill both -expand yes
    pack $f.dframe.del -side bottom -anchor s
    pack $f.dframe.add -side bottom -anchor s
    grid $f.dflbl $f.dframe -row $row -padx 4 -pady 2 -sticky nsew
    incr row

    # Apply/update button
    ttk::button $f.apply -text "Apply Changes" -command cfg::tc_apply_edit
    grid $f.apply -row $row -column 0 -columnspan 2 -pady 8

    grid columnconfigure $f 1 -weight 1
}

# tc_edit holds the currently-displayed toolchain fields
namespace eval ::cfg {
    variable tc_edit
    array set tc_edit {
        name "" cc "" cxx "" ar "" cflags "" cxxflags ""
        ldflags "" defines "" includes "" sysroot ""
        outdir "" opt_levels "" default_olevel ""
    }
    variable tc_names         {}
    variable tc_current       ""
    variable tc_dbgflag_display {}
    variable tc_dbgflags      {}  ;# dict flag->desc for current tc
}

proc cfg::tc_on_select {} {
    set lb  .nb.toolchains.list.lb
    set sel [$lb curselection]
    if {$sel eq {}} return
    set name [$lb get $sel]
    cfg::tc_load_into_editor $name
}

proc cfg::tc_load_into_editor {name} {
    set ::cfg::tc_current $name
    set tc [dict get $::cfg::toolchains $name]

    set ::cfg::tc_edit(name)          $name
    set ::cfg::tc_edit(cc)            [dict get $tc cc]
    set ::cfg::tc_edit(cxx)           [dict get $tc cxx]
    set ::cfg::tc_edit(ar)            [dict get $tc ar]
    set ::cfg::tc_edit(cflags)        [join [dict get $tc cflags] " "]
    set ::cfg::tc_edit(cxxflags)      [join [dict get $tc cxxflags] " "]
    set ::cfg::tc_edit(ldflags)       [join [dict get $tc ldflags] " "]
    set ::cfg::tc_edit(defines)       [join [dict get $tc defines] " "]
    set ::cfg::tc_edit(includes)      [join [dict get $tc includes] " "]
    set ::cfg::tc_edit(sysroot)       [dict get $tc sysroot]
    set ::cfg::tc_edit(outdir)        [dict get $tc outdir]
    set ::cfg::tc_edit(opt_levels)    [join [dict get $tc opt_levels] " "]
    set ::cfg::tc_edit(default_olevel) [dict get $tc default_olevel]

    set ::cfg::tc_dbgflags [dict get $tc debug_flags]
    cfg::tc_refresh_dbgflags
}

proc cfg::tc_refresh_dbgflags {} {
    set ::cfg::tc_dbgflag_display {}
    dict for {flag desc} $::cfg::tc_dbgflags {
        lappend ::cfg::tc_dbgflag_display "$flag  \u2014  $desc"
    }
}

proc cfg::tc_apply_edit {} {
    set new_name [string trim $::cfg::tc_edit(name)]
    if {$new_name eq ""} {
        tk_messageBox -icon warning -title "tclmkcfg" \
            -message "Toolchain name cannot be empty."
        return
    }

    set tc [dict create \
        cc            $::cfg::tc_edit(cc) \
        cxx           $::cfg::tc_edit(cxx) \
        ar            $::cfg::tc_edit(ar) \
        cflags        [split $::cfg::tc_edit(cflags)] \
        cxxflags      [split $::cfg::tc_edit(cxxflags)] \
        ldflags       [split $::cfg::tc_edit(ldflags)] \
        defines       [split $::cfg::tc_edit(defines)] \
        includes      [split $::cfg::tc_edit(includes)] \
        sysroot       $::cfg::tc_edit(sysroot) \
        outdir        $::cfg::tc_edit(outdir) \
        opt_levels    [split $::cfg::tc_edit(opt_levels)] \
        default_olevel $::cfg::tc_edit(default_olevel) \
        debug_flags   $::cfg::tc_dbgflags]

    # Handle rename
    if {$::cfg::tc_current ne "" && \
        $::cfg::tc_current ne $new_name} {
        set ::cfg::toolchains \
            [dict remove $::cfg::toolchains $::cfg::tc_current]
    }

    dict set ::cfg::toolchains $new_name $tc
    set ::cfg::tc_current $new_name
    cfg::refresh_toolchains
    cfg::mark_dirty
    cfg::refresh_preview
}

proc cfg::tc_apply_preset {} {
    set preset_name [.nb.toolchains.editor.preset get]
    set preset [dict get [cfg::presets] $preset_name]

    if {$preset_name eq "Custom"} {
        set ::cfg::tc_edit(name) "custom"
    } else {
        set ::cfg::tc_edit(name) [string tolower \
            [string map {{ } - / - ( {} ) {}} $preset_name]]
    }

    set ::cfg::tc_edit(cc)            [dict get $preset cc]
    set ::cfg::tc_edit(cxx)           [dict get $preset cxx]
    set ::cfg::tc_edit(ar)            [dict get $preset ar]
    set ::cfg::tc_edit(cflags)        [join [dict get $preset cflags] " "]
    set ::cfg::tc_edit(cxxflags)      [join [dict get $preset cxxflags] " "]
    set ::cfg::tc_edit(ldflags)       [join [dict get $preset ldflags] " "]
    set ::cfg::tc_edit(defines)       [join [dict get $preset defines] " "]
    set ::cfg::tc_edit(includes)      [join [dict get $preset includes] " "]
    set ::cfg::tc_edit(sysroot)       [dict get $preset sysroot]
    set ::cfg::tc_edit(outdir)        [dict get $preset outdir]
    set ::cfg::tc_edit(opt_levels)    [join [dict get $preset opt_levels] " "]
    set ::cfg::tc_edit(default_olevel) [dict get $preset default_olevel]
    set ::cfg::tc_dbgflags            [dict get $preset debug_flags]
    cfg::tc_refresh_dbgflags
}

proc cfg::tc_add {} {
    # Clear editor and let user fill in / choose preset
    set ::cfg::tc_current ""
    foreach key [array names ::cfg::tc_edit] {
        set ::cfg::tc_edit($key) ""
    }
    set ::cfg::tc_edit(ar)             ar
    set ::cfg::tc_edit(opt_levels)     "-O0 -O1 -O2 -O3 -Os"
    set ::cfg::tc_edit(default_olevel) -O2
    set ::cfg::tc_dbgflags {}
    cfg::tc_refresh_dbgflags
}

proc cfg::tc_remove {} {
    set lb  .nb.toolchains.list.lb
    set sel [$lb curselection]
    if {$sel eq {}} return
    set name [$lb get $sel]
    set ::cfg::toolchains [dict remove $::cfg::toolchains $name]
    cfg::refresh_toolchains
    cfg::mark_dirty
    cfg::refresh_preview
}

proc cfg::tc_dbgflag_add {} {
    set d [toplevel .dbgflag_add]
    wm title $d "Add Debug Flag"
    wm transient $d .
    wm resizable $d 0 0

    ttk::label  $d.fl -text "Flag:"
    ttk::entry  $d.fe -textvariable ::cfg::dbgflag_new_flag -width 24
    ttk::label  $d.dl -text "Description:"
    ttk::entry  $d.de -textvariable ::cfg::dbgflag_new_desc -width 24
    ttk::button $d.ok -text "Add" -command [list apply {{d} {
        set flag [string trim $::cfg::dbgflag_new_flag]
        set desc [string trim $::cfg::dbgflag_new_desc]
        if {$flag ne ""} {
            dict set ::cfg::tc_dbgflags $flag $desc
            cfg::tc_refresh_dbgflags
        }
        destroy $d
    }} $d]
    ttk::button $d.cancel -text "Cancel" -command [list destroy $d]

    grid $d.fl $d.fe     -padx 6 -pady 4 -sticky ew
    grid $d.dl $d.de     -padx 6 -pady 4 -sticky ew
    grid $d.ok $d.cancel -padx 6 -pady 8
}

proc cfg::tc_dbgflag_remove {} {
    set lb  .nb.toolchains.editor.dframe.lb
    set sel [$lb curselection]
    if {$sel eq {}} return
    set line [$lb get $sel]
    set flag [string trim [lindex [split $line \u2014] 0]]
    set ::cfg::tc_dbgflags [dict remove $::cfg::tc_dbgflags $flag]
    cfg::tc_refresh_dbgflags
}

