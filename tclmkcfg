# Import dialog
# -----------------------------------------------------------------------------
proc cfg::cmake_import_dialog {} {
    set path [tk_getOpenFile \
        -title     "Import CMakeLists.txt" \
        -filetypes {{"CMake" {CMakeLists.txt *.cmake}} {"All Files" *}}]
    if {$path eq ""} return

    # Run the parser
    if {[catch { cmake::parse $path } err]} {
        tk_messageBox -icon error -title "tclmkcfg" \
            -message "Failed to parse CMake file:\n$err"
        return
    }

    # Show results dialog before applying
    cfg::cmake_results_dialog $path
}

proc cfg::cmake_results_dialog {path} {
    set d [toplevel .cmake_results]
    wm title $d "CMake Import Results"
    wm resizable $d 1 1
    wm minsize $d 500 360

    ttk::label $d.lbl \
        -text "Results for [file tail $path]:" \
        -anchor w
    pack $d.lbl -fill x -padx 8 -pady {8 2}

    # Results text widget
    text $d.txt \
        -height 18 -width 64 \
        -font   {TkFixedFont} \
        -state  disabled \
        -wrap   none \
        -yscrollcommand [list $d.sb yview]
    ttk::scrollbar $d.sb -command [list $d.txt yview]
    pack $d.sb  -side right -fill y    -padx {0 4} -pady 4
    pack $d.txt -side left  -fill both -expand yes -padx {8 0} -pady 4

    # Configure tags for colour coding
    $d.txt tag configure ok   -foreground #227722
    $d.txt tag configure skip -foreground #aa7700
    $d.txt tag configure warn -foreground #cc2222

    $d.txt configure -state normal
    foreach entry $::cmake::results {
        lassign $entry status msg
        set prefix [dict get {ok "  ✓ " skip "  ! " warn "  ✗ "} $status]
        $d.txt insert end "$prefix$msg\n" $status
    }
    $d.txt configure -state disabled

    # Summary line
    set nok   [llength [lsearch -all -index 0 $::cmake::results ok]]
    set nskip [llength [lsearch -all -index 0 $::cmake::results skip]]
    set nwarn [llength [lsearch -all -index 0 $::cmake::results warn]]
    ttk::label $d.summary \
        -text "Imported: $nok   Skipped: $nskip   Warnings: $nwarn" \
        -anchor w
    pack $d.summary -fill x -padx 8 -pady {0 4}

    # Buttons
    ttk::frame $d.btns
    ttk::button $d.btns.cancel -text "Cancel" \
        -command [list destroy $d]
    ttk::button $d.btns.apply  -text "Apply to Project" \
        -command [list cfg::cmake_apply_and_close $d]
    pack $d.btns.cancel -side left  -padx 4
    pack $d.btns.apply  -side right -padx 4
    pack $d.btns -fill x -padx 8 -pady {0 8}
}

proc cfg::cmake_apply_and_close {d} {
    destroy $d
    cmake::apply
    cfg::refresh_all
    cfg::mark_dirty
    # Switch to the preview tab so they can see what was generated
    .nb select .nb.preview
}

proc cfg::install_tclmk_dialog {} {
    # Find where tclmkcfg itself lives — tclmk should be alongside it
    set self    [file normalize [info script]]
    set selfdir [file dirname $self]
    set tclmk_src [file join $selfdir tclmk]

    if {![file exists $tclmk_src]} {
        # Not alongside tclmkcfg — ask the user to locate it
        set tclmk_src [tk_getOpenFile \
            -title     "Locate tclmk" \
            -initialdir $selfdir \
            -filetypes {{"tclmk" {tclmk}} {"All Files" *}}]
        if {$tclmk_src eq ""} return
    }

    # Default destination: directory containing the current project file,
    # falling back to cwd if no project is open yet
    set initdir [expr {
        $::cfg::current_file ne ""
            ? [file dirname $::cfg::current_file]
            : [pwd]
    }]

    set dest_dir [tk_chooseDirectory \
        -title       "Install tclmk to..." \
        -initialdir  $initdir]
    if {$dest_dir eq ""} return

    set dest [file join $dest_dir tclmk]

    # Warn if it already exists
    if {[file exists $dest]} {
        set r [tk_messageBox \
            -icon    question \
            -type    yesno \
            -title   "tclmkcfg" \
            -message "tclmk already exists in [file tail $dest_dir].\nOverwrite it?"]
        if {$r ne "yes"} return
    }

    if {[catch {
        file copy -force $tclmk_src $dest
        file attributes $dest -permissions 0755
    } err]} {
        tk_messageBox -icon error -title "tclmkcfg" \
            -message "Failed to install tclmk:\n$err"
        return
    }

    tk_messageBox -icon info -title "tclmkcfg" \
        -message "tclmk installed to $dest"
}

# =============================================================================
# Entry point
# =============================================================================
cfg::build_ui

# Load file from command line if provided
if {[llength $argv] > 0} {
    set f [lindex $argv 0]
    if {[file exists $f]} {
        cfg::open_project $f
    } else {
        # Treat as new project filename
        set ::cfg::current_file $f
        cfg::update_title
    }
} else {
    cfg::refresh_all
}
