# =============================================================================
# CMake Importer
# Best-effort import of CMakeLists.txt into .tclproj state.
# Handles the most common CMake patterns; skips what it cannot parse.
# =============================================================================

namespace eval ::cmake {
    variable vars    {}   ;# dict of CMake variable -> value
    variable results {}   ;# list of {status msg} import report lines
    variable project_name ""
    variable project_version ""
    variable sources  {}
    variable includes {}
    variable defines  {}
    variable ldflags  {}
    variable targets  {}  ;# list of executable/library target names
}

# -----------------------------------------------------------------------------
# Expand ${VAR} references using the current variable dict
# -----------------------------------------------------------------------------
proc cmake::expand {input} {
    # Build the dollar-brace-varname-brace regex via string cat
    # to avoid Tcl brace-counting issues in the source file.
    # chr 123 = open-brace, chr 125 = close-brace
    set ob [format "%c" 123]
    set cb [format "%c" 125]
    set re [string cat {[$]} $ob "(\[^" $cb "\]+)" $cb]
    for {set i 0} {$i < 8} {incr i} {
        set prev   $input
        set output ""
        set pos    0
        while 1 {
            set found [regexp -start $pos -indices \
                -- $re $input whole var]
            if {!$found} {
                append output [string range $input $pos end]
                break
            }
            set w0 [lindex $whole 0]
            set w1 [lindex $whole 1]
            set v0 [lindex $var 0]
            set v1 [lindex $var 1]
            append output [string range $input $pos [expr {$w0 - 1}]]
            set varname [string range $input $v0 $v1]
            if {[dict exists $::cmake::vars $varname]} {
                append output [dict get $::cmake::vars $varname]
            }
            set pos [expr {$w1 + 1}]
        }
        set input $output
        if {$input eq $prev} break
    }
    return $input
}

# -----------------------------------------------------------------------------
# Parse a CMake argument list — handles quoted strings and semicolon lists
# -----------------------------------------------------------------------------
proc cmake::parse_args {raw} {
    # Strip comments
    regsub {#.*$} $raw {} raw
    set raw [string trim $raw]

    set args {}
    set current ""
    set in_quote 0

    foreach ch [split $raw {}] {
        if {$ch eq "\"" } {
            set in_quote [expr {!$in_quote}]
        } elseif {($ch eq " " || $ch eq "\t" || $ch eq "\n") && !$in_quote} {
            if {$current ne ""} {
                if {[catch {cmake::expand $current} expanded]} {
                    set expanded $current
                }
                lappend args $expanded
                set current ""
            }
        } else {
            append current $ch
        }
    }
    if {$current ne ""} {
        if {[catch {cmake::expand $current} expanded]} {
            set expanded $current
        }
        lappend args $expanded
    }
    return $args
}

# -----------------------------------------------------------------------------
# Log a result line
# -----------------------------------------------------------------------------
proc cmake::ok  {msg} { lappend ::cmake::results [list ok  $msg] }
proc cmake::skip {msg} { lappend ::cmake::results [list skip $msg] }
proc cmake::warn {msg} { lappend ::cmake::results [list warn $msg] }

# -----------------------------------------------------------------------------
# Process one CMake command
# -----------------------------------------------------------------------------
proc cmake::handle {cmd argstr} {
    set cmd [string tolower $cmd]
    set args [cmake::parse_args $argstr]

    switch -- $cmd {
        project {
            set ::cmake::project_name [lindex $args 0]
            # Look for VERSION keyword
            set vi [lsearch $args VERSION]
            if {$vi >= 0} {
                set ::cmake::project_version [lindex $args $vi+1]
            }
            cmake::ok "project: [lindex $args 0]"
        }

        set {
            # set(VAR value...)
            if {[llength $args] >= 2} {
                dict set ::cmake::vars [lindex $args 0] \
                    [join [lrange $args 1 end] " "]
            } elseif {[llength $args] == 1} {
                dict unset ::cmake::vars [lindex $args 0]
            }
        }

        add_executable -
        add_library {
            # add_executable(name [STATIC|SHARED] src1 src2 ...)
            set name [lindex $args 0]
            lappend ::cmake::targets $name
            set srcs [lrange $args 1 end]
            # Strip keyword args
            set srcs [lsearch -all -inline -not $srcs \
                -regexp {^(WIN32|MACOSX_BUNDLE|EXCLUDE_FROM_ALL|STATIC|SHARED|MODULE|INTERFACE|OBJECT)$}]
            foreach s $srcs {
                if {[string match *.c $s] || [string match *.cpp $s] \
                        || [string match *.cxx $s] || [string match *.cc $s]} {
                    lappend ::cmake::sources $s
                }
            }
            cmake::ok "$cmd: $name ([llength $srcs] sources)"
        }

        target_sources {
            # target_sources(target PRIVATE|PUBLIC|INTERFACE src...)
            set srcs $args
            # Remove target name and scope keywords
            set srcs [lrange $srcs 1 end]
            set srcs [lsearch -all -inline -not $srcs \
                -regexp {^(PRIVATE|PUBLIC|INTERFACE)$}]
            foreach s $srcs {
                if {[string match *.c $s] || [string match *.cpp $s] \
                        || [string match *.cxx $s] || [string match *.cc $s]} {
                    lappend ::cmake::sources $s
                }
            }
            cmake::ok "target_sources: [llength $srcs] sources"
        }

        include_directories {
            set dirs $args
            set dirs [lsearch -all -inline -not $dirs \
                -regexp {^(BEFORE|AFTER|SYSTEM)$}]
            foreach d $dirs { lappend ::cmake::includes $d }
            cmake::ok "include_directories: [join $dirs {, }]"
        }

        target_include_directories {
            # target_include_directories(target PRIVATE|PUBLIC dir...)
            set dirs [lrange $args 1 end]
            set dirs [lsearch -all -inline -not $dirs \
                -regexp {^(PRIVATE|PUBLIC|INTERFACE)$}]
            foreach d $dirs { lappend ::cmake::includes $d }
            cmake::ok "target_include_directories: [join $dirs {, }]"
        }

        add_compile_definitions -
        target_compile_definitions {
            set defs $args
            if {$cmd eq "target_compile_definitions"} {
                set defs [lrange $defs 1 end]
            }
            set defs [lsearch -all -inline -not $defs \
                -regexp {^(PRIVATE|PUBLIC|INTERFACE)$}]
            foreach d $defs { lappend ::cmake::defines $d }
            cmake::ok "defines: [join $defs {, }]"
        }

        target_link_libraries {
            # target_link_libraries(target PRIVATE|PUBLIC lib...)
            set libs [lrange $args 1 end]
            set libs [lsearch -all -inline -not $libs \
                -regexp {^(PRIVATE|PUBLIC|INTERFACE|LINK_PUBLIC|LINK_PRIVATE)$}]
            foreach lib $libs {
                # Skip cmake targets (no :: means it might be a -l flag or
                # a plain lib name)
                if {[string match *::* $lib]} {
                    cmake::skip "target_link_libraries: $lib (CMake target, skipped)"
                } else {
                    lappend ::cmake::ldflags "-l$lib"
                    cmake::ok "link library: $lib"
                }
            }
        }

        find_package {
            cmake::skip "find_package([lindex $args 0]) — manual dependency entry required"
        }

        add_subdirectory {
            cmake::skip "add_subdirectory([lindex $args 0]) — subdirectory not imported"
        }

        cmake_minimum_required -
        cmake_policy -
        enable_language -
        enable_testing -
        install -
        configure_file -
        set_target_properties -
        set_property -
        get_property -
        add_definitions -
        add_dependencies -
        add_test -
        if -
        elseif -
        else -
        endif -
        foreach -
        endforeach -
        while -
        endwhile -
        function -
        endfunction -
        macro -
        endmacro -
        return -
        break -
        continue -
        list -
        string -
        math -
        file -
        message {}   ;# silently ignore

        default {
            # Warn only on unrecognised commands that look build-related
            if {[string match *flag* $cmd] || [string match *option* $cmd] \
                    || [string match *compile* $cmd]} {
                cmake::skip "$cmd (not imported)"
            }
        }
    }
}

# -----------------------------------------------------------------------------
# Main parser — reads the file and dispatches commands
# -----------------------------------------------------------------------------
proc cmake::parse {path} {
    # Reset state
    set ::cmake::vars           {}
    set ::cmake::results        {}
    set ::cmake::project_name   ""
    set ::cmake::project_version ""
    set ::cmake::sources        {}
    set ::cmake::includes       {}
    set ::cmake::defines        {}
    set ::cmake::ldflags        {}
    set ::cmake::targets        {}

    set fh [open $path r]
    set content [read $fh]
    close $fh

    # Join continuation lines
    regsub -all {\\\n} $content { } content

    # Strip full-line comments
    regsub -all -line {^\s*#[^\n]*} $content {} content

    # Extract commands: CommandName(args)
    # Allow multiline args by using a lazy match
    set pos 0
    set len [string length $content]

    while {$pos < $len} {
        # Find next identifier followed by (
        if {![regexp -start $pos -indices \
                {([A-Za-z_][A-Za-z0-9_]*)\s*\(} $content match cmd_idx]} {
            break
        }

        set cmd_start [lindex $match 0]
        set cmd_end   [lindex $match 1]
        set cmd       [string range $content \
                           [lindex $cmd_idx 0] [lindex $cmd_idx 1]]

        # Find matching closing paren (handle nesting)
        set depth  1
        set i      [expr {$cmd_end + 1}]
        set argbuf ""
        while {$i < $len && $depth > 0} {
            set ch [string index $content $i]
            if     {$ch eq "("} { incr depth }
            elseif {$ch eq ")"} {
                incr depth -1
                if {$depth == 0} break
            }
            append argbuf $ch
            incr i
        }

        if {[catch {cmake::handle $cmd $argbuf} err]} {
            cmake::skip "$cmd: $err"
        }
        set pos [expr {$i + 1}]
    }
}

# -----------------------------------------------------------------------------
# Apply parsed CMake state into cfg:: state
# -----------------------------------------------------------------------------
proc cmake::apply {} {
    # Project metadata
    if {$::cmake::project_name ne ""} {
        dict set ::cfg::meta name    $::cmake::project_name
        dict set ::cfg::meta version $::cmake::project_version
    }

    # Sources — deduplicate
    set seen {}
    foreach s $::cmake::sources {
        if {$s ni $seen} {
            lappend seen $s
            lappend ::cfg::sources [dict create pat $s excl 0]
        }
    }

    # Build a default linux-gcc toolchain from what we found
    set tc [dict create \
        cc              gcc \
        cxx             g++ \
        ar              ar \
        cflags          {-Wall -Wextra} \
        cxxflags        {-Wall -Wextra} \
        ldflags         $::cmake::ldflags \
        defines         $::cmake::defines \
        includes        $::cmake::includes \
        sysroot         {} \
        opt_levels      {-O0 -O1 -O2 -O3 -Os -Oz} \
        default_olevel  -O2 \
        debug_flags     [dict create \
            -g                 "GDB symbols" \
            -fsanitize=address "AddressSanitizer"] \
        outdir          build/linux-gcc \
        targets         [dict create binary [dict create \
            desc "Build binary" deps {} cmds {} default 1]]]

    dict set ::cfg::toolchains linux-gcc $tc
    cmake::ok "Created toolchain: linux-gcc"
}

