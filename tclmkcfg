# =============================================================================
# Dirty tracking
# =============================================================================
proc cfg::mark_dirty {} {
    set ::cfg::dirty 1
    cfg::update_title
}

proc cfg::mark_clean {} {
    set ::cfg::dirty 0
    cfg::update_title
}

proc cfg::update_title {} {
    set name [dict get $::cfg::meta name]
    set title "tclmkcfg"
    if {$name ne ""} { append title " \u2014 $name" }
    if {$::cfg::dirty} { append title " *" }
    wm title . $title
}

# =============================================================================
# .tclproj serializer
# =============================================================================
proc cfg::serialize {} {
    set out {}

    # Project block
    lappend out "project [list [dict get $::cfg::meta name]] \{"
    foreach key {version description license} {
        set v [dict get $::cfg::meta $key]
        if {$v ne ""} {
            lappend out "    $key [list $v]"
        }
    }
    lappend out "\}"
    lappend out ""
    if {$::cfg::sources ne {}} {
        lappend out "sources \{"
        foreach entry $::cfg::sources {
            set pat [dict get $entry pat]
            if {[dict get $entry excl]} {
                lappend out "    exclude [list $pat]"
            } else {
                lappend out "    src     [list $pat]"
            }
        }
        lappend out "\}"
        lappend out ""
    }

    # Toolchain blocks
    dict for {name tc} $::cfg::toolchains {
        lappend out "toolchain [list $name] \{"
        foreach key {cc cxx ar} {
            lappend out "    set $key [list [dict get $tc $key]]"
        }
        # List values
        foreach key {cflags cxxflags ldflags defines includes} {
            set v [dict get $tc $key]
            if {$v ne {}} {
                lappend out "    set $key [list $v]"
            }
        }
        set sr [dict get $tc sysroot]
        if {$sr ne ""} {
            lappend out "    set sysroot [list $sr]"
        }
        lappend out "    set opt_levels     [list [dict get $tc opt_levels]]"
        lappend out "    set default_olevel [list [dict get $tc default_olevel]]"
        # Debug flags as nested dict
        set df [dict get $tc debug_flags]
        if {$df ne {}} {
            lappend out "    set debug_flags \[dict create \\"
            dict for {flag desc} $df {
                lappend out "        [list $flag] [list $desc] \\"
            }
            lappend out "    \]"
        }
        lappend out "    set outdir [list [dict get $tc outdir]]"
        lappend out "\}"
        lappend out ""
    }

    # Dependency blocks
    foreach dep $::cfg::deps {
        lappend out "dependency [list [dict get $dep name]] \{"
        lappend out "    set path     [list [dict get $dep path]]"
        lappend out "    set url      [list [dict get $dep url]]"
        lappend out "    set branch   [list [dict get $dep branch]]"
        set cmds [dict get $dep build_cmds]
        if {$cmds ne {}} {
            lappend out "    set build_cmds [list $cmds]"
        }
        set inc [dict get $dep inc_path]
        if {$inc ne ""} { lappend out "    set inc_path [list $inc]" }
        set lib [dict get $dep lib_path]
        if {$lib ne ""} { lappend out "    set lib_path [list $lib]" }
        set libn [dict get $dep lib_name]
        if {$libn ne ""} { lappend out "    set lib_name [list $libn]" }

        # Per-platform override blocks
        if {[dict exists $dep platforms]} {
            dict for {pname plt} [dict get $dep platforms] {
                lappend out ""
                lappend out "    platform [list $pname] \{"
                set pcmds [dict get $plt build_cmds]
                if {$pcmds ne {}} {
                    lappend out "        set build_cmds [list $pcmds]"
                }
                foreach key {inc_path lib_path lib_name} {
                    set v [dict get $plt $key]
                    if {$v ne ""} {
                        lappend out "        set $key [list $v]"
                    }
                }
                lappend out "    \}"
            }
        }

        lappend out "\}"
        lappend out ""
    }

    # Option blocks
    dict for {name opt} $::cfg::options {
        lappend out "option [list $name] \{"
        lappend out "    set desc      [list [dict get $opt desc]]"
        lappend out "    set default   [dict get $opt default]"
        set plat [dict get $opt platforms]
        if {$plat ne {}} {
            lappend out "    set platforms [list $plat]"
        }
        lappend out "\}"
        lappend out ""
    }

    return [join $out \n]
}

# =============================================================================
# File I/O
# =============================================================================
proc cfg::new_project {} {
    if {![cfg::confirm_discard]} return
    set ::cfg::current_file ""
    set ::cfg::meta [dict create name "" version "0.1.0" \
                         description "" license "0BSD"]
    set ::cfg::sources    {}
    set ::cfg::toolchains {}
    set ::cfg::options    {}
    set ::cfg::deps       {}
    cfg::refresh_all
    cfg::mark_clean
}

proc cfg::open_project {{path ""}} {
    if {![cfg::confirm_discard]} return
    if {$path eq ""} {
        set path [tk_getOpenFile \
            -title   "Open Project" \
            -filetypes {{"tclmk Project" {.tclproj}} {"All Files" *}}]
    }
    if {$path eq ""} return

    # Reset state then parse
    set ::cfg::meta       [dict create name "" version "" description "" license ""]
    set ::cfg::sources    {}
    set ::cfg::toolchains {}
    set ::cfg::options    {}
    set ::cfg::deps       {}

    if {[catch { cfg::parse_file $path } err]} {
        tk_messageBox -icon error -title "tclmkcfg" \
            -message "Failed to open project:\n$err"
        return
    }

    set ::cfg::current_file $path
    cfg::refresh_all
    cfg::mark_clean
}

proc cfg::parse_file {path} {
    # We evaluate the .tclproj DSL in a safe-ish interp that intercepts
    # the DSL commands and populates our state dicts.
    set i [interp create -safe]

    $i alias project    cfg::dsl_project
    $i alias toolchain  cfg::dsl_toolchain
    $i alias sources    cfg::dsl_sources
    $i alias option     cfg::dsl_option
    $i alias dependency cfg::dsl_dependency

    $i eval [read [open $path r]]
    interp delete $i
}

proc cfg::dsl_project {name body} {
    dict set ::cfg::meta name $name
    namespace eval ::cfg::pctx {
        proc version     {v} { set ::cfg::pctx::version     $v }
        proc description {v} { set ::cfg::pctx::description $v }
        proc license     {v} { set ::cfg::pctx::license     $v }
    }
    namespace eval ::cfg::pctx $body
    foreach key {version description license} {
        if {[info exists ::cfg::pctx::$key]} {
            dict set ::cfg::meta $key [set ::cfg::pctx::$key]
        }
    }
    namespace delete ::cfg::pctx
}

proc cfg::dsl_toolchain {name body} {
    set tc [dict create \
        cc "" cxx "" ar ar cflags {} cxxflags {} ldflags {} \
        defines {} includes {} sysroot {} opt_levels {-O0 -O1 -O2 -O3 -Os} \
        default_olevel -O2 debug_flags {} outdir "build/$name"]
    namespace eval ::cfg::tctx $body
    foreach key [dict keys $tc] {
        if {[info exists ::cfg::tctx::$key]} {
            dict set tc $key [set ::cfg::tctx::$key]
        }
    }
    namespace delete ::cfg::tctx
    dict set ::cfg::toolchains $name $tc
}

proc cfg::dsl_sources {body} {
    namespace eval ::cfg::sctx {
        proc src     {pat} { lappend ::cfg::sources \
                                 [dict create pat $pat excl 0] }
        proc exclude {pat} { lappend ::cfg::sources \
                                 [dict create pat $pat excl 1] }
    }
    namespace eval ::cfg::sctx $body
    namespace delete ::cfg::sctx
}

proc cfg::dsl_option {name body} {
    set opt [dict create desc "" default 0 platforms {}]
    namespace eval ::cfg::octx $body
    foreach key [dict keys $opt] {
        if {[info exists ::cfg::octx::$key]} {
            dict set opt $key [set ::cfg::octx::$key]
        }
    }
    namespace delete ::cfg::octx
    dict set ::cfg::options $name $opt
}

proc cfg::dsl_dependency {name body} {
    set dep [dict create \
        name       $name \
        path       "deps/$name" \
        url        "" \
        branch     "main" \
        build_cmds {} \
        inc_path   "" \
        lib_path   "" \
        lib_name   "" \
        platforms  {}]

    namespace eval ::cfg::depctx {
        proc platform {pname pbody} {
            set p [dict create build_cmds {} inc_path "" lib_path "" lib_name ""]
            namespace eval ::cfg::dep_plt_ctx $pbody
            foreach key {build_cmds inc_path lib_path lib_name} {
                if {[info exists ::cfg::dep_plt_ctx::$key]} {
                    dict set p $key [set ::cfg::dep_plt_ctx::$key]
                }
            }
            namespace delete ::cfg::dep_plt_ctx
            dict set ::cfg::depctx::platforms $pname $p
        }
        variable platforms {}
    }

    namespace eval ::cfg::depctx $body

    foreach key {path url branch build_cmds inc_path lib_path lib_name} {
        if {[info exists ::cfg::depctx::$key]} {
            dict set dep $key [set ::cfg::depctx::$key]
        }
    }
    dict set dep platforms $::cfg::depctx::platforms
    namespace delete ::cfg::depctx
    lappend ::cfg::deps $dep
}

proc cfg::save_project {} {
    if {$::cfg::current_file eq ""} {
        cfg::save_as
        return
    }
    cfg::write_file $::cfg::current_file
}

proc cfg::save_as {} {
    set name [dict get $::cfg::meta name]
    set init [expr {$name ne "" ? "${name}.tclproj" : "build.tclproj"}]
    set path [tk_getSaveFile \
        -title       "Save Project As" \
        -initialfile $init \
        -filetypes   {{"tclmk Project" {.tclproj}} {"All Files" *}}]
    if {$path eq ""} return
    set ::cfg::current_file $path
    cfg::write_file $path
}

proc cfg::write_file {path} {
    if {[catch {
        set f [open $path w]
        puts $f [cfg::serialize]
        close $f
    } err]} {
        tk_messageBox -icon error -title "tclmkcfg" \
            -message "Failed to save:\n$err"
        return
    }
    cfg::mark_clean
}

proc cfg::confirm_discard {} {
    if {!$::cfg::dirty} { return 1 }
    set r [tk_messageBox \
        -icon    question \
        -type    yesnocancel \
        -title   "Unsaved Changes" \
        -message "You have unsaved changes. Save before continuing?"]
    switch $r {
        yes    { cfg::save_project; return 1 }
        no     { return 1 }
        cancel { return 0 }
    }
}

# =============================================================================
# Refresh helpers — push state back into UI widgets
# =============================================================================
proc cfg::refresh_all {} {
    cfg::refresh_meta
    cfg::refresh_sources
    cfg::refresh_toolchains
    cfg::refresh_deps
    cfg::refresh_options
    cfg::refresh_preview
    cfg::dep_plt_refresh_checkboxes
    cfg::update_title
}

proc cfg::refresh_toolchains {} {
    set ::cfg::tc_names [dict keys $::cfg::toolchains]
    cfg::dep_plt_refresh_checkboxes
}

# =============================================================================
# UI construction
# =============================================================================
proc cfg::build_ui {} {
    # Menu bar
    menu .mbar
    . configure -menu .mbar

    menu .mbar.file -tearoff 0
    .mbar add cascade -label "File" -menu .mbar.file
    .mbar.file add command -label "New"     -accelerator "Ctrl+N" \
        -command cfg::new_project
    .mbar.file add command -label "Open..." -accelerator "Ctrl+O" \
        -command cfg::open_project
    .mbar.file add separator
    .mbar.file add command -label "Import CMakeLists.txt..." \
        -command cfg::cmake_import_dialog
    .mbar.file add command -label "Install tclmk to Project..." \
        -command cfg::install_tclmk_dialog
    .mbar.file add separator
    .mbar.file add command -label "Save"    -accelerator "Ctrl+S" \
        -command cfg::save_project
    .mbar.file add command -label "Save As..." \
        -command cfg::save_as
    .mbar.file add separator
    .mbar.file add command -label "Quit"    -accelerator "Ctrl+Q" \
        -command cfg::quit

    bind . <Control-n> cfg::new_project
    bind . <Control-o> cfg::open_project
    bind . <Control-s> cfg::save_project
    bind . <Control-q> cfg::quit
    wm protocol . WM_DELETE_WINDOW cfg::quit

    # Main notebook
    ttk::notebook .nb
    pack .nb -fill both -expand yes -padx 4 -pady 4

    .nb add [cfg::make_meta_tab]       -text "Project"
    .nb add [cfg::make_sources_tab]    -text "Sources"
    .nb add [cfg::make_toolchains_tab] -text "Toolchains"
    .nb add [cfg::make_deps_tab]       -text "Dependencies"
    .nb add [cfg::make_options_tab]    -text "Options"
    .nb add [cfg::make_preview_tab]    -text "Preview"
}

# =============================================================================
# Project metadata tab
# =============================================================================
proc cfg::make_meta_tab {} {
    set f [ttk::frame .nb.meta]

    ttk::labelframe $f.fields -text "Project Info"
    pack $f.fields -fill x -padx 8 -pady 8

    set row 0
    foreach {label key} {
        "Name"        name
        "Version"     version
        "License"     license
        "Description" description
    } {
        ttk::label $f.fields.lbl_$key -text "$label:" -anchor e -width 12
        ttk::entry $f.fields.ent_$key \
            -textvariable ::cfg::meta_$key \
            -width 40
        # trace writes back into the dict
        trace add variable ::cfg::meta_$key write \
            [list apply {{key _ _ _} {
                dict set ::cfg::meta $key [set ::cfg::meta_$key]
                cfg::mark_dirty
                cfg::refresh_preview
            }} $key]
        grid $f.fields.lbl_$key $f.fields.ent_$key \
            -row $row -padx 4 -pady 3 -sticky ew
        incr row
    }
    grid columnconfigure $f.fields 1 -weight 1

    return $f
}

proc cfg::refresh_meta {} {
    foreach key {name version license description} {
        set ::cfg::meta_$key [dict get $::cfg::meta $key]
    }
}

# =============================================================================
# Sources tab
# =============================================================================
proc cfg::make_sources_tab {} {
    set f [ttk::frame .nb.sources]

    # Top: pattern entry row
    ttk::labelframe $f.entry -text "Add Source Pattern"
    ttk::label  $f.entry.lbl -text "Pattern:"
    ttk::entry  $f.entry.ent -textvariable ::cfg::src_pattern -width 36
    ttk::label  $f.entry.hint \
        -text "e.g.  src/core/*.c  or  src/main.c" \
        -font {TkSmallCaptionFont}
    ttk::button $f.entry.add  -text "Add \u2192"     \
        -command {cfg::sources_add_pattern 0}
    ttk::button $f.entry.excl -text "Exclude \u2192" \
        -command {cfg::sources_add_pattern 1}
    ttk::button $f.entry.browse -text "Browse..." \
        -command cfg::sources_browse

    grid $f.entry.lbl    -row 0 -column 0 -padx {4 2} -pady 4 -sticky w
    grid $f.entry.ent    -row 0 -column 1 -padx 2     -pady 4 -sticky ew
    grid $f.entry.add    -row 0 -column 2 -padx 2     -pady 4
    grid $f.entry.excl   -row 0 -column 3 -padx 2     -pady 4
    grid $f.entry.browse -row 0 -column 4 -padx {2 4} -pady 4
    grid $f.entry.hint   -row 1 -column 1 -columnspan 4 \
        -padx 2 -pady {0 4} -sticky w
    grid columnconfigure $f.entry 1 -weight 1

    # Bottom: pattern list
    ttk::labelframe $f.list -text "Source Patterns"
    ttk::treeview $f.list.tree \
        -columns {kind pattern} \
        -show headings \
        -selectmode extended \
        -yscrollcommand [list $f.list.sb set]
    $f.list.tree heading kind    -text "Kind"    -anchor w
    $f.list.tree heading pattern -text "Pattern" -anchor w
    $f.list.tree column  kind    -width 70  -stretch 0
    $f.list.tree column  pattern -width 340 -stretch 1
    ttk::scrollbar $f.list.sb -command [list $f.list.tree yview]

    ttk::button $f.list.remove -text "Remove Selected" \
        -command cfg::sources_remove

    grid $f.list.tree   $f.list.sb -sticky nsew
    grid $f.list.remove -          -sticky e -pady {4 2} -padx 2
    grid columnconfigure $f.list 0 -weight 1
    grid rowconfigure    $f.list 0 -weight 1

    grid $f.entry -row 0 -sticky ew   -padx 8 -pady {8 4}
    grid $f.list  -row 1 -sticky nsew -padx 8 -pady {4 8}
    grid columnconfigure $f 0 -weight 1
    grid rowconfigure    $f 1 -weight 1

    return $f
}

set ::cfg::src_pattern ""

proc cfg::sources_add_pattern {excl} {
    set pat [string trim $::cfg::src_pattern]
    if {$pat eq ""} return
    lappend ::cfg::sources [dict create pat $pat excl $excl]
    set ::cfg::src_pattern ""
    cfg::refresh_sources
    cfg::mark_dirty
    cfg::refresh_preview
}

proc cfg::sources_browse {} {
    # Let user pick a file or directory and turn it into a pattern
    set path [tk_getOpenFile -title "Select source file"]
    if {$path eq ""} {
        # Try directory instead
        set path [tk_chooseDirectory -title "Select source directory"]
        if {$path eq ""} return
        set ::cfg::src_pattern "$path/*.c"
    } else {
        set ::cfg::src_pattern $path
    }
}

proc cfg::sources_remove {} {
    set tree .nb.sources.list.tree
    set sel  [$tree selection]
    if {$sel eq {}} return
    set indices {}
    foreach item $sel {
        lappend indices [$tree index $item]
    }
    foreach idx [lsort -integer -decreasing $indices] {
        set ::cfg::sources [lreplace $::cfg::sources $idx $idx]
    }
    cfg::refresh_sources
    cfg::mark_dirty
    cfg::refresh_preview
}

proc cfg::refresh_sources {} {
    set tree .nb.sources.list.tree
    if {![winfo exists $tree]} return
    $tree delete [$tree children {}]
    foreach entry $::cfg::sources {
        set pat  [dict get $entry pat]
        set excl [dict get $entry excl]
        set kind [expr {$excl ? "exclude" : "src"}]
        set tag  [expr {$excl ? "excl" : "src"}]
        $tree insert {} end -values [list $kind $pat] -tags $tag
    }
    $tree tag configure excl -foreground red
    $tree tag configure src  -foreground black
}

